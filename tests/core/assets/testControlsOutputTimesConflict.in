# Test input deck for SimControls: both output_time_dist and output_times
# specified at once (invalid -- only one option may be given)

sim_type = "cluster"

[stars]
IMF = "chabrier.toml"
track_registry = "tests/tracks/assets/tracks.toml"
tracks = "MIST_test"
FeH = 0.0
alphaFe = -0.2

[clusters]
CMF = 1e3

[outputs]
output_time_dist = 5.0
output_times = [1.0, 2.0]
