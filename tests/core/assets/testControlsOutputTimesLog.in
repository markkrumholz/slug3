# Test input deck for SimControls: log-spaced start_time/end_time/ntime grid (option 3a)

sim_type = "cluster"

[stars]
IMF = "chabrier.toml"
track_registry = "tests/tracks/assets/tracks.toml"
tracks = "MIST_test"
FeH = 0.0
alphaFe = -0.2

[clusters]
CMF = 1e3

[outputs]
start_time = 1.0
end_time = 100.0
ntime = 3
log_time = true
