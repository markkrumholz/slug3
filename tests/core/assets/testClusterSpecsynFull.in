# Full end-to-end test input deck for
# tests/core/testClusterSpecsynFull.cpp: drives a complete run through
# SimCluster using the real MIST tracks and the real POWR_WC/POWR_WNE/
# POWR_WNL/TLUSTY_O/TLUSTY_B/BOSZ/CK04 spectral libraries (not the
# small test fixtures used elsewhere), so this only runs if that data
# -- too large to store in the repository -- has been fetched locally
# (see data/tools/fetch_mist.py, fetch_powr.py, fetch_tlusty.py,
# fetch_bosz.py, fetch_ck04.py). spectra.model lists TLUSTY_O and
# TLUSTY_B separately, rather than a single combined TLUSTY entry,
# since fetch_tlusty.py now fetches PoWR's O-star and B-star grids
# (different recommended default microturbulent velocities) into
# separate registry entries; together they span 15000-55000 K, closing
# the 16000-27500 K gap this test originally found between BOSZ and
# the old single TLUSTY grid. CK04 is listed last, after BOSZ, since
# it exists specifically to catch stars in BOSZ's own gaps -- BOSZ has
# essentially no models for Teff >~ 8000 K combined with log g <~ 1.5,
# a real hole this test also found, which CK04 (a fully rectangular
# grid through that same region) fills. Output times span 2-10 Myr to
# capture stellar evolution before, during, and after the Wolf-Rayet
# phase.
#
# FeH is pinned to a delta function at exactly 0.0 for now, rather
# than a flat distribution over a range, because MIST's real feh=-0.50
# (afe=0.0, v_vcrit=0.4) track group is short two masses (1.95 and
# 2.00 Msun) relative to its neighbors -- confirmed present in the
# published MIST tracks themselves, not an artifact of our own
# packaging -- and Tracks3D requires every bracketed [Fe/H] group to
# share an identical mass grid. Tracks3D also always expands whatever
# [Fe/H] range it's given by one extra grid point on each side (to
# support GSL's Steffen interpolation along that axis), so -- given
# the 0.25 dex grid spacing near solar metallicity -- any range with
# fehMin < 0, however close to 0, still pulls in feh=-0.50 as either
# its lower bracket or that bracket's expansion neighbor; only an
# exact fehMin == fehMax on a single grid point (here, 0.0) skips that
# expansion entirely. Revert this to a flat range once the MIST
# maintainers confirm whether a corrected tarball is coming.

sim_type = "cluster"
# n_trial must appear here, before any [table] header -- TOML has no
# way to return to the root table once a header opens one, so a bare
# key placed after e.g. [outputs] below would silently become
# outputs.n_trial instead of the top-level key SimControls actually
# reads. (Exactly this mistake previously left every run of this test
# at the n_trial=1 default without erroring, since every earlier run
# failed on a spectral-synthesis gap before the trial count ever
# mattered.)
n_trial = 10

[stars]
IMF = "chabrier.toml"
tracks = "MIST"
v_vcrit = 0.4
alphaFe = 0.0
FeH = 0.0

[spectra]
model = ["POWR_WC", "POWR_WNE", "POWR_WNL", "TLUSTY_O", "TLUSTY_B", "BOSZ", "CK04"]

[clusters]
CMF = 1e4

[outputs]
output_times = [2e6, 3e6, 4e6, 1e7]
