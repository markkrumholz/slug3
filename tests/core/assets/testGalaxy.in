# This is a test criptic input deck for a galaxy simulation

sim_type = "galaxy"

[stars]
IMF = "chabrier.toml"
track_registry = "tests/tracks/assets/tracks.toml"
tracks = "MIST_test"
alphaFe = -0.2
FeH = 0.0

[clusters]
CMF = 1e3
CLF = 1e300

[galaxy]
sfr = 1.0

[outputs]
start_time = 0.0
end_time = 10.0
ntime = 3