# Test input deck for SimControls: explicit model_name, verbosity, and n_trial

sim_type = "cluster"
model_name = "my_test_model"
verbosity = 3
n_trial = 7

[stars]
IMF = "chabrier.toml"
track_registry = "tests/tracks/assets/tracks.toml"
tracks = "MIST_test"
FeH = 0.0
alphaFe = -0.2

[clusters]
CMF = 1e3

[outputs]
start_time = 0.0
end_time = 10.0
ntime = 3
