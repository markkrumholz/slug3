# Test input deck for SimControls: a galaxy-type simulation with
# output_clusters left at its default (true)

sim_type = "galaxy"

[stars]
IMF = "chabrier.toml"
track_registry = "tests/tracks/assets/tracks.toml"
tracks = "MIST_test"
FeH = 0.0
alphaFe = -0.2

[clusters]
CMF = 1e3
CLF = 1e300

[galaxy]
sfr = 1.0

[outputs]
start_time = 0.0
end_time = 10.0
ntime = 3
