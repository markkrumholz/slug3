# Test input deck for SimControls: start_time/end_time given without ntime
# (invalid -- all three of start_time, end_time, and ntime must be given together)

sim_type = "cluster"

[stars]
IMF = "chabrier.toml"
track_registry = "tests/tracks/assets/tracks.toml"
tracks = "MIST_test"
FeH = 0.0
alphaFe = -0.2

[clusters]
CMF = 1e3

[outputs]
start_time = 0.0
end_time = 10.0
